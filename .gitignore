# These are some examples of commonly ignored file patterns.
# You should customize this list as applicable to your project.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/
dist/

# JetBrains IDE
.idea/*

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# ...except the landing-page hero, a tracked docs asset (regenerate: make hero)
!docs/assets/video/scrollkit-hero.mp4

**/.claude/settings.local.json

# Local agent config and Spec Kit framework scaffolding (specs/ themselves are
# tracked; the .specify/ engine and .claude/ tooling are local-only).
.claude/
.specify/

# mkdocs build output
site/

# runtime logs (incl. rotated `error_log.old` generations from ErrorHandler)
logs/
demos/error_log*
error_log*

# mpy build output
build/

# Python caches / envs
__pycache__/
.pytest_cache/
.venv/
venv/
*.egg-info/

# Runtime settings (created by the web UI; must never land in source control)
settings.json

# Phase-0 spike generated output (test/claude/spike_out): rendered PNG/PPM frames
test/claude/spike_out/
